#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to get the actual installation directory
REAL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "${REAL_PATH}")/.." && pwd)"

case "${1:-}" in
    install)
        exec bash "${ROOT_DIR}/bootstrap/install.sh" "${@:2}"
        ;;
    update)
        exec bash "${ROOT_DIR}/bootstrap/update.sh" "${@:2}"
        ;;
    doctor)
        exec bash "${ROOT_DIR}/bootstrap/doctor.sh" "${@:2}"
        ;;
    repair)
        exec bash "${ROOT_DIR}/bootstrap/repair.sh" "${@:2}"
        ;;
    uninstall)
        exec bash "${ROOT_DIR}/bootstrap/uninstall.sh" "${@:2}"
        ;;
    verify)
        exec bash "${ROOT_DIR}/bootstrap/verify.sh" "${@:2}"
        ;;
    *)
        echo "Intema Panel CLI"
        echo "Usage: intema <install|update|doctor|repair|uninstall|verify>"
        exit 1
        ;;
esac
