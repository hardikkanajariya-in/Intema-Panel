APP_NAME="Intema Panel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@hardikkanajariya.in"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Panel Branding
PANEL_NAME="Intema Panel"
PANEL_TAGLINE="Open Source Lightweight Hosting Control Panel"
PANEL_COMPANY="Hardik Kanajariya"
PANEL_WEBSITE="https://hardikkanajariya.in"
PANEL_GITHUB="https://github.com/hardikkanajariya/intema-panel"
PANEL_SUPPORT_EMAIL="hello@hardikkanajariya.in"
PANEL_VERSION="1.0.0"
PANEL_TIMEZONE="UTC"
PANEL_THEME="system"
PANEL_DATABASE_PREFIX="client_"
PANEL_DEFAULT_CLIENT_STATUS="active"

# PostgreSQL Administration
PANEL_PG_HOST=127.0.0.1
PANEL_PG_PORT=5432
PANEL_PG_ADMIN_USER=postgres
PANEL_PG_ADMIN_PASSWORD=

# Shell Execution
PANEL_SCRIPTS_PATH=
PANEL_SHELL_TIMEOUT=60
PANEL_SHELL_ENABLED=true

# Administrator (used by install.sh)
ADMIN_NAME="Administrator"
ADMIN_EMAIL="admin@localhost"
ADMIN_PASSWORD=
